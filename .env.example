# Copy to .env (gitignored) and fill in.
# Used by the MedGemma client to talk to a local oMLX server.

# Where the oMLX server is listening. Default is the OpenAI-compatible local port.
OMLX_BASE_URL=http://localhost:8000/v1

# A dummy key is required by the openai client but is not validated by oMLX.
# Generate a random value once; treat it as a secret anyway.
OMLX_API_KEY=replace-me

# Local model id served by oMLX (must match the value passed to omlx serve).
OMLX_MODEL_ID=mlx-community/medgemma-1.5-4b-it-bf16

# Where the served weights live on disk; used by scripts/compute_model_sha.sh.
OMLX_MODEL_DIR=/absolute/path/to/cache/mlx-community--medgemma-1.5-4b-it-bf16

# Optional: where MIMIC-IV and MIMIC-IV-WDB live on disk (otherwise pass via CLI flags).
MIMIC_IV_ROOT=/absolute/path/to/mimic-iv-3.1
WDB_ROOT=/absolute/path/to/mimic4wdb/0.1.0
